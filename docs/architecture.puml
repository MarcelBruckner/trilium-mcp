@startuml architecture
title Trilium ETAPI MCP — deployment

left to right direction
skinparam linetype ortho
skinparam shadowing false
skinparam nodesep 50
skinparam ranksep 130
skinparam defaultTextAlignment center
skinparam rectangle {
    BackgroundColor #F5F7FA
    BorderColor #8A94A6
    roundCorner 12
}
skinparam database {
    BackgroundColor #F5F7FA
    BorderColor #8A94A6
}
skinparam ArrowColor #4A5568

together {
    actor "MCP client\n(via reverse proxy)" as C1
    actor "MCP client\n(direct, trusted LAN)" as C2
}

rectangle "reverse proxy\n(optional — TLS)" as Proxy #FFF6E5

rectangle "Docker host / compose network" as Host #EEF2F7 {
    rectangle "mcp sidecar\n(this repo)\n:8081 /mcp" as MCP
    rectangle "trilium\n:8080 /etapi" as Trilium
    database "trilium-data\n(volume)" as Data
}

C1 --> Proxy : HTTPS
C2 --> MCP : HTTP (LAN)
Proxy --> MCP : /mcp
MCP --> Trilium : ETAPI
Trilium --> Data : notes

@enduml
